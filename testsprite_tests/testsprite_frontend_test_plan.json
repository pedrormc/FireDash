[
  {
    "id": "TC001",
    "title": "Successful registration redirects to Login with success message",
    "description": "Verifies a new user can register with valid details, sees a success message, and is redirected to the Login page.",
    "category": "User Registration",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Click on the \"Register\" link"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Create\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Test User\" into the name field"
      },
      {
        "type": "action",
        "description": "Type \"newuser_20260311_001@bombeiros.gov.br\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"Bombeiro Civil\" into the cargo field"
      },
      {
        "type": "action",
        "description": "Select \"operator\" from the role dropdown"
      },
      {
        "type": "action",
        "description": "Type \"ValidPass123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Type \"ValidPass123!\" into the confirm password field"
      },
      {
        "type": "action",
        "description": "Click on \"Register\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"success\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Login\" is visible"
      }
    ]
  },
