  {
    "id": "TC008",
    "title": "Admin/Operador can view dashboard KPIs, filter incidents, and delete an incident successfully",
    "description": "Verifies that a permitted user can see KPI/charts, apply filters to update the incident table, and delete an incident with confirmation and success feedback.",
    "category": "Dashboard & Incidents",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"admin@bombeiros.gov.br\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"admin123\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"KPI cards\" is visible"
      },
      {
        "type": "action",
        "description": "Select an option from the \"Periodo\" filter dropdown"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Incident table\" is visible"
      }
    ]
  },
