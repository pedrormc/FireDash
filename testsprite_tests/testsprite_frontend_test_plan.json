  {
    "id": "TC011",
    "title": "Admin/Operador deletes an incident after confirming in the confirmation dialog",
    "description": "Verifies the end-to-end delete flow: open confirmation, confirm deletion, and see success notification and removed row.",
    "category": "Dashboard & Incidents",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"admin@bombeiros.gov.br\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"admin123\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Incident table\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Delete\" button on the first incident row"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Confirm deletion\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Confirm\" button"
      }
    ]
  },
