# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# DATABASE_URL: Conexão PostgreSQL (VPS)
# Formato: postgresql://user:password@host:5432/bombeiros
DATABASE_URL="postgresql://user:password@localhost:5432/bombeiros"

# JWT_SECRET: Chave secreta para gerar tokens JWT
JWT_SECRET="minha-chave-secreta"

# DB_SSL: Usar SSL na conexão com o banco (true/false)
DB_SSL="false"

# PORT: Porta do backend (padrão: 3001)
PORT="3001"

# CORS_ORIGIN: Origem permitida para CORS (frontend URL)
CORS_ORIGIN="http://localhost:3000"

# VITE_API_URL: URL base da API (usado pelo frontend)
VITE_API_URL="http://localhost:3001/api"
